{
  "name": "floodguard-frontend",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://floodguard-backend.onrender.com/api/:path*"
    },
    {
      "source": "/ws",
      "destination": "https://floodguard-backend.onrender.com/ws"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
